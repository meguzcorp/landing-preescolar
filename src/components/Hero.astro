---
// src/components/Hero.astro
import { getLangFromUrl, useTranslations } from "../i18n/utils";

// Detectamos el idioma actual y preparamos la traducción
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<style>
  /* Importamos tus fuentes locales */
  @font-face {
    font-family: "AvenusType";
    src: url("/fonts/AvenusType.otf") format("opentype");
  }
  @font-face {
    font-family: "CeraPro";
    src: url("/fonts/CeraProRegular.otf") format("opentype");
    font-weight: 400;
  }
  @font-face {
    font-family: "CeraPro";
    src: url("/fonts/CeraProBlack.otf") format("opentype");
    font-weight: 900;
  }

  .font-avenus {
    font-family: "AvenusType", sans-serif;
    font-style: normal !important;
  }

  .font-cera {
    font-family: "CeraPro", sans-serif;
  }

  /* La mancha verde decorativa del panel blanco */
  .panel-formulario::after {
    content: "";
    position: absolute;
    bottom: -10px;
    left: -10px;
    width: 200px;
    height: 150px;
    background-image: url("/mancha-verde.png");
    background-size: contain;
    background-repeat: no-repeat;
    background-position: left bottom;
    z-index: -1;
  }
  .animate-shake {
    animation: shake 0.4s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
  }
  @keyframes shake {
    10%,
    90% {
      transform: translate3d(-1px, 0, 0);
    }
    20%,
    80% {
      transform: translate3d(2px, 0, 0);
    }
    30%,
    50%,
    70% {
      transform: translate3d(-4px, 0, 0);
    }
    40%,
    60% {
      transform: translate3d(4px, 0, 0);
    }
  }
</style>

<section
  class="relative min-h-[600px] flex items-center py-20 overflow-visible"
>
  <div class="absolute inset-0 z-0">
    <img
      src="/background.webp"
      alt="background"
      class="w-full h-full object-fill"
    />
  </div>

  <div
    class="relative z-10 max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center"
  >
    <div class="hidden md:block">
      <img
        src="/kids.webp"
        alt="Alumnos Colegio Inglés"
        class="w-full h-auto drop-shadow-2xl"
      />
    </div>

    <div
      class="panel-formulario relative bg-white p-10 rounded-[45px] shadow-2xl overflow-hidden"
    >
      <h3
        class="font-avenus text-center text-[#001D85] text-4xl md:text-5xl leading-none mb-8"
      >
        {t("form.title")}
        <br />
        <span
          class="font-cera font-black text-[#9BB836] text-[0.7em] block mt-2"
        >
          {t("form.span")}
        </span>
      </h3>

      <form id="formHeroLanding" class="space-y-4 relative z-10">
        <div
          class="flex items-stretch border-2 border-[#9BB836] rounded-[25px] overflow-hidden h-[45px]"
        >
          <span
            class="bg-[#9BB836] flex items-center justify-center px-4 text-white"
          >
            <i class="glyphicon">👤</i>
          </span>
          <input
            type="text"
            name="nombre"
            placeholder={t("form.name")}
            class="flex-1 px-4 outline-none text-[#9BB836] placeholder:text-[#9BB836]/60 bg-transparent"
          />
        </div>

        <div
          class="flex items-stretch border-2 border-[#9BB836] rounded-[25px] overflow-hidden h-[45px]"
        >
          <span
            class="bg-[#9BB836] flex items-center justify-center px-4 text-white"
          >
            <i class="glyphicon">✏️</i>
          </span>
          <input
            type="text"
            name="escuela_procedencia"
            placeholder={t("form.school")}
            class="flex-1 px-4 outline-none text-[#9BB836] bg-transparent placeholder:text-[#9BB836]/60"
          />
        </div>

        <div
          class="flex items-stretch border-2 border-[#9BB836] rounded-[25px] overflow-hidden h-[45px]"
        >
          <span
            class="bg-[#9BB836] flex items-center justify-center px-4 text-white"
          >
            <i class="glyphicon">🎓</i>
          </span>
          <select
            name="nivel_interes"
            class="flex-1 px-4 outline-none text-[#9BB836] bg-transparent appearance-none"
          >
            <option value="">{t("form.interest")}</option>
            <option value="Maternal">Maternal</option>
            <option value="Preescolar">Preescolar</option>
          </select>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div
            class="flex items-stretch border-2 border-[#9BB836] rounded-[25px] overflow-hidden h-[45px]"
          >
            <span
              class="bg-[#9BB836] flex items-center justify-center px-4 text-white"
            >
              <i class="glyphicon">📧</i>
            </span>
            <input
              type="email"
              name="correo"
              placeholder={t("form.email")}
              class="flex-1 px-4 outline-none text-[#9BB836] bg-transparent placeholder:text-[#9BB836]/60"
            />
          </div>
          <div
            class="flex items-stretch border-2 border-[#9BB836] rounded-[25px] overflow-hidden h-[45px]"
          >
            <span
              class="bg-[#9BB836] flex items-center justify-center px-4 text-white"
            >
              <i class="glyphicon">📞</i>
            </span>
            <input
              type="tel"
              name="telefono"
              placeholder={t("form.phone")}
              class="flex-1 px-4 outline-none text-[#9BB836] bg-transparent placeholder:text-[#9BB836]/60"
            />
          </div>
        </div>

        <div class="flex justify-end pt-4">
          <button
            type="submit"
            class="bg-[#9BB836] hover:bg-[#8aa82d] text-white font-cera font-medium px-10 py-2 rounded-[15px] shadow-[0_4px_0px_#7a9b1a] active:translate-y-[2px] active:shadow-none transition-all"
          >
            {t("form.submit")}
          </button>
          <div
            id="form-feedback"
            class="hidden mt-4 p-3 rounded-lg text-sm text-center"
          >
          </div>
        </div>
      </form>
    </div>
  </div>
</section>
<script>
  const form = document.getElementById("formHeroLanding") as HTMLFormElement;

  // 1. Referencias a los elementos del Modal (que ya vive en el index)
  const modal = document.getElementById("modal-response");
  const iconSuccess = document.getElementById("icon-success");
  const iconError = document.getElementById("icon-error");
  const modalTitle = document.getElementById("modal-title");
  const modalText = document.getElementById("modal-text");

  function openModal(title: string, text: string, isError = false) {
    if (!modal || !modalTitle || !modalText || !iconSuccess || !iconError)
      return;

    // Resetear y mostrar icono correcto
    iconSuccess.classList.toggle("hidden", isError);
    iconError.classList.toggle("hidden", !isError);

    modalTitle.textContent = title;
    modalText.textContent = text;

    // Mostrar con animación
    modal.classList.remove("hidden");
    setTimeout(() => modal.classList.remove("opacity-0"), 10);
  }

  // 2. Función para manejar los bordes rojos en los contenedores de los inputs
  function toggleErrorStyle(inputName: string, hasError: boolean) {
    const input = form.querySelector(`[name="${inputName}"]`);
    const container = input?.parentElement; // Seleccionamos el div con borde verde

    if (container) {
      if (hasError) {
        container.classList.add("border-red-500", "animate-shake");
        container.classList.remove("border-[#9BB836]");
      } else {
        container.classList.remove("border-red-500", "animate-shake");
        container.classList.add("border-[#9BB836]");
      }
    }
  }

  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const submitBtn = form.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement;
      const originalContent = submitBtn.innerHTML;

      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      const fields = ["nombre", "correo", "telefono", "nivel_interes"];
      let isValid = true;

      // Validar cada campo y pintar bordes
      fields.forEach((field) => {
        const value = formData.get(field) as string;
        let hasError = !value;

        if (field === "correo" && value && !emailRegex.test(value))
          hasError = true;
        if (
          field === "telefono" &&
          value &&
          value.replace(/\D/g, "").length !== 10
        )
          hasError = true;

        toggleErrorStyle(field, hasError);
        if (hasError) isValid = false;
      });

      if (!isValid) {
        openModal(
          "¡Casi listo!",
          "Por favor revisa los campos marcados en rojo para continuar.",
          true,
        );
        return;
      }

      try {
        submitBtn.disabled = true;
        // 3. Insertar el Spinner de carga
        submitBtn.innerHTML = `
          <div class="flex items-center justify-center">
            <svg class="animate-spin h-5 w-5 text-white mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Enviando...
          </div>
        `;

        const response = await fetch("/api/contacto", {
          method: "POST",
          body: formData,
        });

        if (response.ok) {
          openModal(
            "¡Registro Exitoso!",
            "Gracias por interesarte en Colegio Inglés. Pronto nos comunicaremos contigo.",
          );
          form.reset();
        } else {
          throw new Error();
        }
      } catch {
        openModal(
          "Hubo un detalle",
          "No pudimos enviar tu información. Por favor, intenta de nuevo más tarde.",
          true,
        );
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalContent;
      }
    });
  }
</script>
